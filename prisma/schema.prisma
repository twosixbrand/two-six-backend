enum GenderEnum {
  MASCULINO
  FEMENINO
  UNISEX
}

model Coupon {
  id                       Int           @id @default(autoincrement())
  code                     String        @unique @db.VarChar(50)
  percentage               Float         @default(0)
  free_shipping            Boolean       @default(false)
  valid_from               DateTime
  valid_until              DateTime
  is_single_use_per_client Boolean       @default(false)
  is_active                Boolean       @default(true)
  max_uses                 Int?
  current_uses             Int           @default(0)
  min_purchase_amount      Float?
  min_items_count          Int?
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime?     @updatedAt @map("updated_at")
  orders                   Order[]
  usages                   CouponUsage[]

  @@map("coupon")
}

model CouponUsage {
  id          Int      @id @default(autoincrement())
  id_coupon   Int      @map("id_coupon")
  id_customer Int      @map("id_customer")
  id_order    Int      @unique @map("id_order")
  used_at     DateTime @default(now())

  coupon   Coupon   @relation(fields: [id_coupon], references: [id], onDelete: Restrict)
  customer Customer @relation(fields: [id_customer], references: [id], onDelete: Restrict)
  order    Order    @relation(fields: [id_order], references: [id], onDelete: Restrict)

  @@map("coupon_usage")
}
