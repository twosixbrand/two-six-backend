generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ErrorLog {
  id             Int       @id @default(autoincrement())
  message        String
  stack          String?
  componentStack String?   @map("component_stack")
  app            String?   @db.VarChar(4)
  page           String?   @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  @@map("log_error")
}

model UserApp {
  login        String     @unique
  name         String
  createdAt    DateTime   @default(now()) @map("created_at")
  email        String     @unique
  id           Int        @id @default(autoincrement()) @map("id_user_app")
  updatedAt    DateTime?  @updatedAt @map("updated_at")
  phone        String
  password     String?
  otp          String?
  otpExpiresAt DateTime?  @map("otp_expires_at")
  userRoles    UserRole[]

  @@map("user_app")
}

model Role {
  name        String     @unique
  createdAt   DateTime   @default(now()) @map("created_at")
  description String?
  id          Int        @id @default(autoincrement()) @map("id_role")
  updatedAt   DateTime?  @updatedAt @map("updated_at")
  userRoles   UserRole[]

  @@map("role")
}

model UserRole {
  createdAt   DateTime  @default(now()) @map("created_at")
  id          Int       @id @default(autoincrement())
  id_role     Int       @map("id_role")
  id_user_app Int       @map("id_user_app")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  role        Role      @relation(fields: [id_role], references: [id])
  user        UserApp   @relation(fields: [id_user_app], references: [id])

  @@map("user_role")
}

model Provider {
  id              String              @id @map("nit")
  email           String              @unique
  account_number  String              @map("account_number")
  account_type    String              @map("account_type")
  bank_name       String              @map("bank_name")
  company_name    String              @map("company_name")
  createdAt       DateTime            @default(now()) @map("created_at")
  phone           String
  updatedAt       DateTime?           @updatedAt @map("updated_at")
  designProviders DesignProvider[]
  documents       ProviderDocument[]

  @@map("provider")
}

model ProviderDocument {
  id            Int      @id @default(autoincrement())
  provider_id   String
  document_type String   @map("document_type")
  file_url      String   @map("file_url")
  file_name     String   @map("file_name")
  uploaded_at   DateTime @default(now()) @map("uploaded_at")
  provider      Provider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@map("provider_document")
}

model YearProduction {
  createdAt   DateTime     @default(now()) @map("created_at")
  description String?
  id          String       @id @db.Char(2)
  name        String
  updatedAt   DateTime?    @updatedAt @map("updated_at")
  collections Collection[]

  @@map("year_production")
}

model Season {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime?    @updatedAt @map("updated_at")
  collections Collection[]

  @@map("season")
}

model Collection {
  description        String?
  createdAt          DateTime       @default(now()) @map("created_at")
  id                 Int            @id @default(autoincrement())
  updatedAt          DateTime?      @updatedAt @map("updated_at")
  id_season          Int            @map("id_season")
  id_year_production String         @map("id_year_production") @db.Char(2)
  name               String
  season             Season         @relation(fields: [id_season], references: [id])
  yearProduction     YearProduction @relation(fields: [id_year_production], references: [id])
  designs            Design[]

  @@map("collection")
}

model TypeClothing {
  id        String     @id @db.Char(2)
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  clothing  Clothing[]

  @@map("type_clothing")
}

model Category {
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  id        Int        @id @default(autoincrement())
  updatedAt DateTime?  @updatedAt @map("updated_at")
  clothing  Clothing[]

  @@map("category")
}

model Gender {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime?  @updatedAt
  clothing  Clothing[]

  @@map("gender")
}

model Clothing {
  name             String
  createdAt        DateTime     @default(now()) @map("created_at")
  id_category      Int          @map("id_category")
  id_type_clothing String       @map("id_type_clothing") @db.Char(2)
  updatedAt        DateTime?    @updatedAt @map("updated_at")
  id               Int          @id @default(autoincrement())
  id_gender        Int?         @map("id_gender")
  category         Category     @relation(fields: [id_category], references: [id])
  gender           Gender?      @relation(fields: [id_gender], references: [id])
  typeClothing     TypeClothing @relation(fields: [id_type_clothing], references: [id])
  designs          Design[]

  @@map("clothing")
}

model Color {
  id            Int             @id @default(autoincrement())
  name          String
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime?       @updatedAt @map("updated_at")
  hex           String
  clothingColor ClothingColor[]

  @@map("color")
}

model Size {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime?      @updatedAt @map("updated_at")
  clothingSizes ClothingSize[]

  @@map("size")
}

model SizeGuide {
  id        Int       @id @default(autoincrement())
  size      String
  width     String
  length    String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("size_guide")
}

model Design {
  id                Int              @id @default(autoincrement())
  id_clothing       Int              @map("id_clothing")
  id_collection     Int              @map("id_collection")
  reference         String
  manufactured_cost Float
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime?        @updatedAt @map("updated_at")
  description       String?
  image_url         String?          @map("image_url")
  clothingColors    ClothingColor[]
  clothing          Clothing         @relation(fields: [id_clothing], references: [id])
  collection        Collection       @relation(fields: [id_collection], references: [id])
  designProviders   DesignProvider[]

  @@map("design")
}

model ProductionType {
  id              Int              @id @default(autoincrement()) @map("id_production_type")
  name            String
  creationDate    DateTime         @default(now()) @map("created_at")
  updateDate      DateTime         @updatedAt @map("updated_at")
  designProviders DesignProvider[]

  @@map("production_type")
}

model DesignProvider {
  id                 Int            @id @default(autoincrement())
  id_design          Int            @map("id_design")
  id_provider        String         @map("id_provider")
  id_production_type Int            @map("id_production_type")
  start_date         DateTime?
  end_date           DateTime?
  price              Decimal
  rating             Int?
  comment            String?
  creationDate       DateTime       @default(now()) @map("created_at")
  updateDate         DateTime?      @updatedAt @map("updated_at")
  design             Design         @relation(fields: [id_design], references: [id])
  productionType     ProductionType @relation(fields: [id_production_type], references: [id])
  provider           Provider       @relation(fields: [id_provider], references: [id])

  @@map("design_provider")
}

model ClothingColor {
  id            Int             @id @default(autoincrement())
  id_color      Int             @map("id_color")
  id_design     Int             @map("id_design")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime?       @updatedAt @map("updated_at")
  color         Color           @relation(fields: [id_color], references: [id])
  design        Design          @relation(fields: [id_design], references: [id])
  clothingSizes ClothingSize[]
  imageClothing ImageClothing[]

  @@map("clothing_color")
}

model ImageClothing {
  id_image_clothing Int           @id @default(autoincrement())
  id_clothing_color Int           @map("id_clothing_color")
  image_url         String?       @map("image_url")
  position          Int
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime?     @updatedAt @map("updated_at")
  clothingColor     ClothingColor @relation(fields: [id_clothing_color], references: [id])

  @@map("image_clothing")
}

model ClothingSize {
  id                      Int           @id @default(autoincrement())
  id_size                 Int           @map("id_size")
  id_clothing_color       Int           @map("id_clothing_color")
  quantity_produced       Int
  quantity_available      Int
  quantity_sold           Int
  quantity_on_consignment Int
  quantity_under_warranty Int           @default(0) @map("quantity_under_warranty")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime?     @updatedAt @map("updated_at")
  quantity_minimum_alert  Int?          @map("quantity_minimum_alert")
  clothingColor           ClothingColor @relation(fields: [id_clothing_color], references: [id])
  size                    Size          @relation(fields: [id_size], references: [id])
  product                 Product?

  @@map("clothing_size")
}

model Product {
  id                  Int          @id @default(autoincrement())
  price               Float
  active              Boolean
  updatedAt           DateTime?    @updatedAt @map("updated_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  is_outlet           Boolean      @map("is_outlet")
  sku                 String?
  discount_percentage Float?
  discount_price      Float?
  id_clothing_size    Int          @unique @map("id_clothing_size")
  orderItems          OrderItem[]
  clothingSize        ClothingSize @relation(fields: [id_clothing_size], references: [id])
  returnItems         ReturnItem[]

  @@map("product")
}

model Customer {
  id_customer_type       Int                @map("id_customer_type")
  id_identification_type Int                @map("id_identification_type")
  name                   String
  email                  String             @unique
  current_phone_number   String
  responsable_for_vat    Boolean
  shipping_address       String
  city                   String
  state                  String
  postal_code            String
  country                String
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime?          @updatedAt @map("updated_at")
  id                     Int                @id @default(autoincrement())
  otp                    String?
  otpExpiresAt           DateTime?          @map("otp_expires_at")
  is_registered          Boolean            @default(false) @map("is_registered")
  addresses              Address[]
  customerType           CustomerType       @relation(fields: [id_customer_type], references: [id])
  identificationType     IdentificationType @relation(fields: [id_identification_type], references: [id])
  order                  Order[]
  payments               Payments[]
  returns                Returns[]

  @@map("customer")
}

model Address {
  id           Int       @id @default(autoincrement())
  id_customer  Int       @map("id_customer")
  address      String
  detail       String?
  instructions String?
  city         String
  state        String
  postal_code  String
  country      String
  is_default   Boolean   @default(false) @map("is_default")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  customer     Customer  @relation(fields: [id_customer], references: [id])

  @@map("address")
}

model CustomerType {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  customers Customer[]

  @@map("customer_type")
}

model IdentificationType {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  code      String
  customers Customer[]

  @@map("identification_type")
}

model Order {
  id               Int             @id @default(autoincrement()) @map("id_order")
  order_reference  String?         @unique
  id_customer      Int             @map("id_customer")
  order_date       DateTime
  status           String
  is_paid          Boolean
  shipping_address String
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime?       @updatedAt @map("updated_at")
  iva              Float
  purchase_date    DateTime        @map("purchase_date")
  shipping_cost    Float           @map("shipping_cost")
  total_payment    Float           @map("total_payment")
  dianEInvoicing   DianEInvoicing?
  customer         Customer        @relation(fields: [id_customer], references: [id])
  orderItems       OrderItem[]
  payments         Payments[]
  returns          Returns[]
  shipments        Shipment[]

  @@map("order")
}

model OrderItem {
  id           Int          @id @default(autoincrement())
  id_order     Int          @map("id_order")
  id_product   Int          @map("id_product")
  product_name String
  size         String
  color        String
  quantity     Int
  unit_price   Float
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime?    @updatedAt @map("updated_at")
  iva_item     Float        @map("iva_item")
  order        Order        @relation(fields: [id_order], references: [id])
  product      Product      @relation(fields: [id_product], references: [id])
  returnItems  ReturnItem[]

  @@map("order_item")
}

model Returns {
  id              Int          @id @default(autoincrement())
  id_order        Int          @map("id_order")
  id_customer     Int          @map("id_customer")
  type            String
  reason          String
  status          String
  request_date    DateTime
  refund_amount   Float
  shipping_method String
  tracking        String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime?    @updatedAt @map("updated_at")
  returnItems     ReturnItem[]
  customer        Customer     @relation(fields: [id_customer], references: [id])
  order           Order        @relation(fields: [id_order], references: [id])

  @@map("returns")
}

model ReturnItem {
  id            Int       @id @default(autoincrement())
  id_return     Int       @map("id_return")
  id_order_item Int       @map("id_order_item")
  id_product    Int       @map("id_product")
  quantity      Int
  reason_return String
  condition     String
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  orderItem     OrderItem @relation(fields: [id_order_item], references: [id])
  product       Product   @relation(fields: [id_product], references: [id])
  return        Returns   @relation(fields: [id_return], references: [id])

  @@map("return_item")
}

model PaymentMethod {
  id        Int        @id @default(autoincrement())
  name      String
  enabled   Boolean
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  payments  Payments[]

  @@map("payment_method")
}

model Payments {
  id                    Int           @id @default(autoincrement())
  id_order              Int           @map("id_order")
  id_customer           Int           @map("id_customer")
  id_payment_method     Int           @map("id_payment_method")
  status                String
  transaction_date      DateTime
  transaction_reference String
  amount                Float
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime?     @updatedAt @map("updated_at")
  customer              Customer      @relation(fields: [id_customer], references: [id])
  order                 Order         @relation(fields: [id_order], references: [id])
  paymentMethod         PaymentMethod @relation(fields: [id_payment_method], references: [id])

  @@map("payments")
}

model DianEInvoicing {
  id              Int       @id @default(autoincrement())
  id_order        Int       @unique @map("id_order")
  cufe_code       String
  qr_code         String
  document_number String
  issue_date      DateTime
  due_date        DateTime
  status          String
  url_pdf         String
  url_xml         String
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")
  order           Order     @relation(fields: [id_order], references: [id])

  @@map("dian_e_invoicing")
}

model ShippingProvider {
  id                Int            @id @default(autoincrement())
  name              String
  set_tracking_base String
  active            Boolean
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime?      @updatedAt @map("updated_at")
  shipments         Shipment[]
  shipmentRates     ShipmentRate[]

  @@map("shipping_provider")
}

model ShipmentRate {
  id                       Int              @id @default(autoincrement())
  id_shipping_provider     Int              @map("id_shipping_provider")
  destination_zone         String
  weight_unit              String
  base_cost                Float
  cost_per_additional_unit Float
  estimated_delivery_time  String
  shipping_code            String
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime?        @updatedAt @map("updated_at")
  shippingProvider         ShippingProvider @relation(fields: [id_shipping_provider], references: [id])

  @@map("shipment_rate")
}

model Shipment {
  id                      Int               @id @default(autoincrement())
  id_order                Int               @map("id_order")
  id_shipping_provider    Int               @map("id_shipping_provider")
  guide_number            String
  status                  String
  estimated_delivery_date DateTime
  delivery_date           DateTime?
  id_tracking             String?
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime?         @updatedAt @map("updated_at")
  order                   Order             @relation(fields: [id_order], references: [id])
  shippingProvider        ShippingProvider  @relation(fields: [id_shipping_provider], references: [id])
  trackingHistory         TrackingHistory[]

  @@map("shipment")
}

model TrackingHistory {
  id            Int       @id @default(autoincrement())
  id_shipment   Int       @map("id_shipment")
  status        String
  update_date   DateTime
  location      String
  provider_code String
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  shipment      Shipment  @relation(fields: [id_shipment], references: [id])

  @@map("tracking_history")
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  cities    City[]

  @@map("department")
}

model City {
  id            Int        @id @default(autoincrement())
  name          String
  active        Boolean    @default(true)
  shipping_cost Int        @default(0)
  id_department Int        @map("id_department")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime?  @updatedAt @map("updated_at")
  department    Department @relation(fields: [id_department], references: [id])

  @@map("city")
}

enum GenderEnum {
  MASCULINO
  FEMENINO
  UNISEX
}

model Subscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  registeredAt DateTime @default(now()) @map("registered_at")
  status           Boolean  @default(true)
  unsubscribed     Boolean  @default(false)
  discount_code    String?  @unique
  is_discount_used Boolean  @default(false)

  @@map("subscriber")
}

model Pqr {
  id             Int       @id @default(autoincrement())
  radicado       String    @unique
  customer_name  String
  customer_id    String    // Cédula o NIT
  customer_email String
  order_number   String?
  type           String    // Petición, Queja, Reclamo, Sugerencia
  description    String    @db.Text
  observation    String?   @db.Text
  status         String    @default("Abierto") // Abierto, En Revisión, Resuelto, Cerrado
  slaRiskAlertSent Boolean @default(false)
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime?  @updatedAt @map("updated_at")
  images         PqrImage[]

  @@map("pqr")
}

model PqrImage {
  id        Int       @id @default(autoincrement())
  id_pqr    Int       @map("id_pqr")
  image_url String    @map("image_url")
  createdAt DateTime  @default(now()) @map("created_at")
  pqr       Pqr       @relation(fields: [id_pqr], references: [id], onDelete: Cascade)

  @@map("pqr_image")
}
