model Employee {
  id                     Int            @id @default(autoincrement())
  document_number        String         @unique @map("document_number")
  id_identification_type Int            @map("id_identification_type")
  name                   String
  position               String
  department             String?
  hire_date              DateTime       @map("hire_date")
  base_salary            Float          @map("base_salary")
  transport_allowance    Float          @default(0) @map("transport_allowance")
  is_active              Boolean        @default(true) @map("is_active")
  eps_entity             String?        @map("eps_entity")
  pension_fund           String?        @map("pension_fund")
  arl_risk_level         Int            @default(1) @map("arl_risk_level")
  bank_name              String?        @map("bank_name")
  bank_account           String?        @map("bank_account")
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime?      @updatedAt @map("updated_at")
  contract_type          String         @default("INDEFINIDO") @map("contract_type")
  is_exonerated          Boolean        @default(true) @map("is_exonerated")
  payrollEntries         PayrollEntry[]

  @@map("employee")
}

model PayrollPeriod {
  id          Int            @id @default(autoincrement())
  year        Int
  month       Int
  period_type String         @map("period_type")
  start_date  DateTime       @map("start_date")
  end_date    DateTime       @map("end_date")
  status      String         @default("DRAFT")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime?      @updatedAt @map("updated_at")
  entries     PayrollEntry[]

  @@map("payroll_period")
}

model PayrollEntry {
  id                      Int           @id @default(autoincrement())
  id_payroll_period       Int           @map("id_payroll_period")
  id_employee             Int           @map("id_employee")
  base_salary             Float         @map("base_salary")
  transport_allowance     Float         @default(0) @map("transport_allowance")
  worked_days             Int           @default(30) @map("worked_days")
  overtime_amount         Float         @default(0) @map("overtime_amount")
  commissions             Float         @default(0)
  bonuses                 Float         @default(0)
  gross_salary            Float         @map("gross_salary")
  health_employee         Float         @default(0) @map("health_employee")
  pension_employee        Float         @default(0) @map("pension_employee")
  health_employer         Float         @default(0) @map("health_employer")
  pension_employer        Float         @default(0) @map("pension_employer")
  arl_employer            Float         @default(0) @map("arl_employer")
  sena_employer           Float         @default(0) @map("sena_employer")
  icbf_employer           Float         @default(0) @map("icbf_employer")
  caja_employer           Float         @default(0) @map("caja_employer")
  prima_provision         Float         @default(0) @map("prima_provision")
  cesantias_provision     Float         @default(0) @map("cesantias_provision")
  int_cesantias_provision Float         @default(0) @map("int_cesantias_provision")
  vacaciones_provision    Float         @default(0) @map("vacaciones_provision")
  net_salary              Float         @map("net_salary")
  total_employer_cost     Float         @map("total_employer_cost")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime?     @updatedAt @map("updated_at")
  hed_qty                 Float         @default(0) @map("hed_qty")
  hedf_qty                Float         @default(0) @map("hedf_qty")
  hen_qty                 Float         @default(0) @map("hen_qty")
  henf_qty                Float         @default(0) @map("henf_qty")
  ibc                     Float         @default(0) @map("ibc")
  other_accruals          Float         @default(0) @map("other_accruals")
  other_deductions        Float         @default(0) @map("other_deductions")
  rf_qty                  Float         @default(0) @map("rf_qty")
  rn_qty                  Float         @default(0) @map("rn_qty")
  employee                Employee      @relation(fields: [id_employee], references: [id])
  payrollPeriod           PayrollPeriod @relation(fields: [id_payroll_period], references: [id])

  @@map("payroll_entry")
}

model InventoryKardex {
  id               Int          @id @default(autoincrement())
  id_clothing_size Int          @map("id_clothing_size")
  date             DateTime     @default(now())
  type             String
  source_type      String
  source_id        Int?         @map("source_id")
  quantity         Int
  balance_before   Int          @map("balance_before")
  balance_after    Int          @map("balance_after")
  unit_cost        Float?       @map("unit_cost")
  description      String?
  createdAt        DateTime     @default(now()) @map("created_at")
  clothingSize     ClothingSize @relation(fields: [id_clothing_size], references: [id])

  @@map("inventory_kardex")
}

model InventoryAdjustment {
  id               Int                       @id @default(autoincrement())
  adjustment_date  DateTime                  @default(now()) @map("adjustment_date")
  reason           String
  description      String?
  status           String                    @default("COMPLETED")
  id_user          Int?                      @map("id_user")
  id_journal_entry Int?                      @map("id_journal_entry")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime?                 @updatedAt @map("updated_at")
  journalEntry     JournalEntry?             @relation(fields: [id_journal_entry], references: [id])
  items            InventoryAdjustmentItem[]

  @@map("inventory_adjustment")
}

model InventoryAdjustmentItem {
  id                      Int                 @id @default(autoincrement())
  id_inventory_adjustment Int                 @map("id_inventory_adjustment")
  id_clothing_size        Int                 @map("id_clothing_size")
  quantity                Int
  unit_cost               Float               @map("unit_cost")
  clothingSize            ClothingSize        @relation(fields: [id_clothing_size], references: [id])
  adjustment              InventoryAdjustment @relation(fields: [id_inventory_adjustment], references: [id], onDelete: Cascade)

