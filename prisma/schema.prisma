generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ErrorLog {
  id             Int       @id @default(autoincrement())
  message        String
  stack          String?
  componentStack String?   @map("component_stack")
  app            String?   @db.VarChar(4)
  page           String?   @db.VarChar(50)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  @@map("log_error")
}

model UserApp {
  login        String     @unique
  name         String
  createdAt    DateTime   @default(now()) @map("created_at")
  email        String     @unique
  id           Int        @id @default(autoincrement()) @map("id_user_app")
  updatedAt    DateTime?  @updatedAt @map("updated_at")
  phone        String
  password     String?
  otp          String?
  otpExpiresAt DateTime?  @map("otp_expires_at")
  userRoles    UserRole[]

  @@map("user_app")
}

model Role {
  name        String     @unique
  createdAt   DateTime   @default(now()) @map("created_at")
  description String?
  id          Int        @id @default(autoincrement()) @map("id_role")
  updatedAt   DateTime?  @updatedAt @map("updated_at")
  userRoles   UserRole[]

  @@map("role")
}

model UserRole {
  createdAt   DateTime  @default(now()) @map("created_at")
  id          Int       @id @default(autoincrement())
  id_role     Int       @map("id_role")
  id_user_app Int       @map("id_user_app")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  role        Role      @relation(fields: [id_role], references: [id])
  user        UserApp   @relation(fields: [id_user_app], references: [id])

  @@map("user_role")
}

model Provider {
  id              String             @id @map("nit")
  email           String             @unique
  account_number  String             @map("account_number")
  account_type    String             @map("account_type")
  bank_name       String             @map("bank_name")
  company_name    String             @map("company_name")
  createdAt       DateTime           @default(now()) @map("created_at")
  phone           String
  updatedAt       DateTime?          @updatedAt @map("updated_at")
  designProviders         DesignProvider[]
  documents               ProviderDocument[]
  expenses                Expense[]
  withholdingCertificates WithholdingCertificate[]

  @@map("provider")
}

model ProviderDocument {
  id            Int      @id @default(autoincrement())
  provider_id   String
  document_type String   @map("document_type")
  file_url      String   @map("file_url")
  file_name     String   @map("file_name")
  uploaded_at   DateTime @default(now()) @map("uploaded_at")
  provider      Provider @relation(fields: [provider_id], references: [id], onDelete: Cascade)

  @@map("provider_document")
}

model YearProduction {
  createdAt   DateTime     @default(now()) @map("created_at")
  description String?
  id          String       @id @db.Char(2)
  name        String
  updatedAt   DateTime?    @updatedAt @map("updated_at")
  collections Collection[]

  @@map("year_production")
}

model Season {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime?    @updatedAt @map("updated_at")
  collections Collection[]

  @@map("season")
}

model Collection {
  description        String?
  createdAt          DateTime       @default(now()) @map("created_at")
  id                 Int            @id @default(autoincrement())
  updatedAt          DateTime?      @updatedAt @map("updated_at")
  id_season          Int            @map("id_season")
  id_year_production String         @map("id_year_production") @db.Char(2)
  name               String
  season             Season         @relation(fields: [id_season], references: [id])
  yearProduction     YearProduction @relation(fields: [id_year_production], references: [id])
  designs            Design[]

  @@map("collection")
}

model TypeClothing {
  id        String     @id @db.Char(2)
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  clothing  Clothing[]

  @@map("type_clothing")
}

model Category {
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  id        Int        @id @default(autoincrement())
  updatedAt DateTime?  @updatedAt @map("updated_at")
  clothing  Clothing[]

  @@map("category")
}

model Gender {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime?  @updatedAt
  clothing  Clothing[]

  @@map("gender")
}

model Clothing {
  name             String
  createdAt        DateTime     @default(now()) @map("created_at")
  id_category      Int          @map("id_category")
  id_type_clothing String       @map("id_type_clothing") @db.Char(2)
  updatedAt        DateTime?    @updatedAt @map("updated_at")
  id               Int          @id @default(autoincrement())
  id_gender        Int?         @map("id_gender")
  category         Category     @relation(fields: [id_category], references: [id])
  gender           Gender?      @relation(fields: [id_gender], references: [id])
  typeClothing     TypeClothing @relation(fields: [id_type_clothing], references: [id])
  designs          Design[]

  @@map("clothing")
}

model Color {
  id            Int             @id @default(autoincrement())
  name          String
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime?       @updatedAt @map("updated_at")
  hex           String
  clothingColor ClothingColor[]

  @@map("color")
}

model Size {
  id            Int            @id @default(autoincrement())
  name          String
  description   String?
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime?      @updatedAt @map("updated_at")
  clothingSizes ClothingSize[]

  @@map("size")
}

model SizeGuide {
  id        Int       @id @default(autoincrement())
  size      String
  width     String
  length    String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  @@map("size_guide")
}

model Design {
  id                Int              @id @default(autoincrement())
  id_clothing       Int              @map("id_clothing")
  id_collection     Int              @map("id_collection")
  reference         String
  manufactured_cost Float
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime?        @updatedAt @map("updated_at")
  description       String?
  image_url         String?          @map("image_url")
  clothingColors    ClothingColor[]
  clothing          Clothing         @relation(fields: [id_clothing], references: [id])
  collection        Collection       @relation(fields: [id_collection], references: [id])
  designProviders   DesignProvider[]

  @@map("design")
}

model ProductionType {
  id              Int              @id @default(autoincrement()) @map("id_production_type")
  name            String
  creationDate    DateTime         @default(now()) @map("created_at")
  updateDate      DateTime         @updatedAt @map("updated_at")
  designProviders DesignProvider[]

  @@map("production_type")
}

model DesignProvider {
  id                 Int            @id @default(autoincrement())
  id_design          Int            @map("id_design")
  id_provider        String         @map("id_provider")
  id_production_type Int            @map("id_production_type")
  start_date         DateTime?
  end_date           DateTime?
  price              Decimal
  rating             Int?
  comment            String?
  creationDate       DateTime       @default(now()) @map("created_at")
  updateDate         DateTime?      @updatedAt @map("updated_at")
  design             Design         @relation(fields: [id_design], references: [id])
  productionType     ProductionType @relation(fields: [id_production_type], references: [id])
  provider           Provider       @relation(fields: [id_provider], references: [id])

  @@map("design_provider")
}

model ClothingColor {
  id            Int             @id @default(autoincrement())
  id_color      Int             @map("id_color")
  id_design     Int             @map("id_design")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime?       @updatedAt @map("updated_at")
  color         Color           @relation(fields: [id_color], references: [id])
  design        Design          @relation(fields: [id_design], references: [id])
  clothingSizes ClothingSize[]
  imageClothing ImageClothing[]

  @@map("clothing_color")
}

model ImageClothing {
  id_image_clothing Int           @id @default(autoincrement())
  id_clothing_color Int           @map("id_clothing_color")
  image_url         String?       @map("image_url")
  position          Int
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime?     @updatedAt @map("updated_at")
  clothingColor     ClothingColor @relation(fields: [id_clothing_color], references: [id])

  @@map("image_clothing")
}

model ClothingSize {
  id                      Int           @id @default(autoincrement())
  id_size                 Int           @map("id_size")
  id_clothing_color       Int           @map("id_clothing_color")
  quantity_produced       Int
  quantity_available      Int
  quantity_sold           Int
  quantity_on_consignment Int
  quantity_under_warranty Int           @default(0) @map("quantity_under_warranty")
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime?     @updatedAt @map("updated_at")
  quantity_minimum_alert  Int?          @map("quantity_minimum_alert")
  clothingColor           ClothingColor @relation(fields: [id_clothing_color], references: [id])
  size                    Size          @relation(fields: [id_size], references: [id])
  product                 Product?

  @@map("clothing_size")
}

model Product {
  id                  Int          @id @default(autoincrement())
  price               Float
  active              Boolean
  updatedAt           DateTime?    @updatedAt @map("updated_at")
  createdAt           DateTime     @default(now()) @map("created_at")
  is_outlet           Boolean      @map("is_outlet")
  sku                 String?
  discount_percentage Float?
  discount_price      Float?
  id_clothing_size    Int          @unique @map("id_clothing_size")
  orderItems          OrderItem[]
  clothingSize        ClothingSize @relation(fields: [id_clothing_size], references: [id])
  returnItems         ReturnItem[]

  @@map("product")
}

model Customer {
  id_customer_type       Int                @map("id_customer_type")
  id_identification_type Int                @map("id_identification_type")
  document_number        String?            @unique
  name                   String
  email                  String
  current_phone_number   String
  responsable_for_vat    Boolean
  shipping_address       String
  city                   String
  state                  String
  postal_code            String
  country                String
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime?          @updatedAt @map("updated_at")
  id                     Int                @id @default(autoincrement())
  otp                    String?
  otpExpiresAt           DateTime?          @map("otp_expires_at")
  is_registered          Boolean            @default(false) @map("is_registered")
  addresses              Address[]
  customerType           CustomerType       @relation(fields: [id_customer_type], references: [id])
  identificationType     IdentificationType @relation(fields: [id_identification_type], references: [id])
  order                  Order[]
  payments               Payments[]
  returns                Returns[]

  @@map("customer")
}

model Address {
  id           Int       @id @default(autoincrement())
  id_customer  Int       @map("id_customer")
  address      String
  detail       String?
  instructions String?
  city         String
  state        String
  postal_code  String
  country      String
  is_default   Boolean   @default(false) @map("is_default")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")
  customer     Customer  @relation(fields: [id_customer], references: [id])

  @@map("address")
}

model CustomerType {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  customers Customer[]

  @@map("customer_type")
}

model IdentificationType {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  code      String
  customers Customer[]

  @@map("identification_type")
}

model Order {
  id               Int              @id @default(autoincrement()) @map("id_order")
  order_reference  String?          @unique
  id_customer      Int              @map("id_customer")
  order_date       DateTime
  status           String
  is_paid          Boolean
  shipping_address String
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime?        @updatedAt @map("updated_at")
  iva              Float
  purchase_date    DateTime         @map("purchase_date")
  shipping_cost    Float            @map("shipping_cost")
  total_payment    Float            @map("total_payment")
  payment_method   String           @default("WOMPI_FULL") @map("payment_method")
  cod_amount       Float            @default(0) @map("cod_amount")
  delivery_method  String           @default("SHIPPING") @map("delivery_method")
  pickup_status    String?          @map("pickup_status")
  pickup_pin       String?          @map("pickup_pin")
  dianEInvoicings  DianEInvoicing[]
  customer         Customer         @relation(fields: [id_customer], references: [id])
  orderItems       OrderItem[]
  payments         Payments[]
  returns          Returns[]
  shipments        Shipment[]

  @@map("order")
}

model OrderItem {
  id           Int          @id @default(autoincrement())
  id_order     Int          @map("id_order")
  id_product   Int          @map("id_product")
  product_name String
  size         String
  color        String
  quantity     Int
  unit_price   Float
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime?    @updatedAt @map("updated_at")
  iva_item     Float        @map("iva_item")
  order        Order        @relation(fields: [id_order], references: [id])
  product      Product      @relation(fields: [id_product], references: [id])
  returnItems  ReturnItem[]

  @@map("order_item")
}

model Returns {
  id              Int          @id @default(autoincrement())
  id_order        Int          @map("id_order")
  id_customer     Int          @map("id_customer")
  type            String
  reason          String
  status          String
  request_date    DateTime
  refund_amount   Float
  shipping_method String
  tracking        String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime?    @updatedAt @map("updated_at")
  returnItems     ReturnItem[]
  customer        Customer     @relation(fields: [id_customer], references: [id])
  order           Order        @relation(fields: [id_order], references: [id])

  @@map("returns")
}

model ReturnItem {
  id            Int       @id @default(autoincrement())
  id_return     Int       @map("id_return")
  id_order_item Int       @map("id_order_item")
  id_product    Int       @map("id_product")
  quantity      Int
  reason_return String
  condition     String
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  orderItem     OrderItem @relation(fields: [id_order_item], references: [id])
  product       Product   @relation(fields: [id_product], references: [id])
  return        Returns   @relation(fields: [id_return], references: [id])

  @@map("return_item")
}

model PaymentMethod {
  id        Int        @id @default(autoincrement())
  name      String
  enabled   Boolean
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")
  payments  Payments[]

  @@map("payment_method")
}

model Payments {
  id                    Int           @id @default(autoincrement())
  id_order              Int           @map("id_order")
  id_customer           Int           @map("id_customer")
  id_payment_method     Int           @map("id_payment_method")
  status                String
  transaction_date      DateTime
  transaction_reference String
  amount                Float
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime?     @updatedAt @map("updated_at")
  customer              Customer      @relation(fields: [id_customer], references: [id])
  order                 Order         @relation(fields: [id_order], references: [id])
  paymentMethod         PaymentMethod @relation(fields: [id_payment_method], references: [id])

  @@map("payments")
}

model DianEInvoicing {
  id                 Int             @id @default(autoincrement())
  id_order           Int?            @map("id_order")
  id_dian_resolution Int?            @map("id_dian_resolution")
  cufe_code          String?
  qr_code            String?
  document_number    String
  issue_date         DateTime
  due_date           DateTime
  status             String
  url_pdf            String?
  url_xml            String?
  dian_response      String?         @db.Text
  dian_zip_base64    String?         @map("dian_zip_base64") @db.Text
  environment        String          @default("TEST") // "TEST" o "PRODUCTION"
  email_sent         Boolean         @default(false) @map("email_sent")
  dian_authorized_at DateTime?       @map("dian_authorized_at")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime?       @updatedAt @map("updated_at")
  order              Order?          @relation(fields: [id_order], references: [id])
  dianResolution     DianResolution? @relation(fields: [id_dian_resolution], references: [id])
  dianNotes          DianNote[]

  @@map("dian_e_invoicing")
}

model DianResolution {
  id               Int       @id @default(autoincrement())
  type             String // 'INVOICE', 'CREDIT_NOTE', 'DEBIT_NOTE'
  prefix           String?
  resolutionNumber String    @map("resolution_number")
  startNumber      Int       @map("start_number")
  endNumber        Int       @map("end_number")
  currentNumber    Int       @default(0) @map("current_number")
  technicalKey     String?   @map("technical_key")
  startDate        DateTime  @map("start_date")
  endDate          DateTime  @map("end_date")
  environment      String    @default("TEST") // 'TEST', 'PRODUCTION'
  testSetId        String?   @map("test_set_id") // Only for TEST
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  dianInvoices DianEInvoicing[]

  @@map("dian_resolution")
}

model DianNote {
  id               Int       @id @default(autoincrement())
  id_dian_invoice  Int       @map("id_dian_invoice")
  type             String // "CREDIT" o "DEBIT"
  note_number      String?   @unique @map("note_number") // Ej: NC1, ND1
  cude             String?   @unique // Equivalente al CUFE para Notas
  issue_date       DateTime? @map("issue_date")
  reason_code      String    @map("reason_code") // Catálogo DIAN
  reason_desc      String?   @map("reason_desc")
  amount           Float // Valor de la nota
  xml_url          String?   @map("xml_url")
  pdf_url          String?   @map("pdf_url")
  status           String    @default("PENDING") // PENDING, SENT, ERROR
  status_message   String?   @map("status_message") @db.Text
  dian_status_code String?   @map("dian_status_code")
  dian_zip_base64  String?   @map("dian_zip_base64") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  dianEInvoicing DianEInvoicing @relation(fields: [id_dian_invoice], references: [id])

  @@map("dian_note")
}

model ShippingProvider {
  id                Int            @id @default(autoincrement())
  name              String
  set_tracking_base String
  active            Boolean
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime?      @updatedAt @map("updated_at")
  shipments         Shipment[]
  shipmentRates     ShipmentRate[]

  @@map("shipping_provider")
}

model ShipmentRate {
  id                       Int              @id @default(autoincrement())
  id_shipping_provider     Int              @map("id_shipping_provider")
  destination_zone         String
  weight_unit              String
  base_cost                Float
  cost_per_additional_unit Float
  estimated_delivery_time  String
  shipping_code            String
  createdAt                DateTime         @default(now()) @map("created_at")
  updatedAt                DateTime?        @updatedAt @map("updated_at")
  shippingProvider         ShippingProvider @relation(fields: [id_shipping_provider], references: [id])

  @@map("shipment_rate")
}

model Shipment {
  id                      Int               @id @default(autoincrement())
  id_order                Int               @map("id_order")
  id_shipping_provider    Int               @map("id_shipping_provider")
  guide_number            String
  status                  String
  estimated_delivery_date DateTime
  delivery_date           DateTime?
  id_tracking             String?
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime?         @updatedAt @map("updated_at")
  order                   Order             @relation(fields: [id_order], references: [id])
  shippingProvider        ShippingProvider  @relation(fields: [id_shipping_provider], references: [id])
  trackingHistory         TrackingHistory[]

  @@map("shipment")
}

model TrackingHistory {
  id            Int       @id @default(autoincrement())
  id_shipment   Int       @map("id_shipment")
  status        String
  update_date   DateTime
  location      String
  provider_code String
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  shipment      Shipment  @relation(fields: [id_shipment], references: [id])

  @@map("tracking_history")
}

model Department {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")
  cities    City[]

  @@map("department")
}

model City {
  id            Int        @id @default(autoincrement())
  name          String
  active        Boolean    @default(true)
  shipping_cost Int        @default(0)
  id_department Int        @map("id_department")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime?  @updatedAt @map("updated_at")
  department    Department @relation(fields: [id_department], references: [id])

  @@map("city")
}

enum GenderEnum {
  MASCULINO
  FEMENINO
  UNISEX
}

model Subscriber {
  id               Int      @id @default(autoincrement())
  email            String   @unique
  registeredAt     DateTime @default(now()) @map("registered_at")
  status           Boolean  @default(true)
  unsubscribed     Boolean  @default(false)
  discount_code    String?  @unique
  is_discount_used Boolean  @default(false)

  @@map("subscriber")
}

model Pqr {
  id               Int        @id @default(autoincrement())
  radicado         String     @unique
  customer_name    String
  customer_id      String // Cédula o NIT
  customer_email   String
  order_number     String?
  type             String // Petición, Queja, Reclamo, Sugerencia
  description      String     @db.Text
  observation      String?    @db.Text
  status           String     @default("Abierto") // Abierto, En Revisión, Resuelto, Cerrado
  slaRiskAlertSent Boolean    @default(false)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime?  @updatedAt @map("updated_at")
  images           PqrImage[]

  @@map("pqr")
}

model PqrImage {
  id        Int      @id @default(autoincrement())
  id_pqr    Int      @map("id_pqr")
  image_url String   @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  pqr       Pqr      @relation(fields: [id_pqr], references: [id], onDelete: Cascade)

  @@map("pqr_image")
}

// ═══════════════════════════════════════════════════════
// MÓDULO CONTABLE - Plan Único de Cuentas (PUC)
// ═══════════════════════════════════════════════════════

model PucAccount {
  id                Int       @id @default(autoincrement())
  code              String    @unique @db.VarChar(10)
  name              String
  level             Int       // 1=Clase, 2=Grupo, 3=Cuenta, 4=Subcuenta, 5=Auxiliar
  nature            String    @db.VarChar(10) // DEBITO o CREDITO
  parent_code       String?   @map("parent_code") @db.VarChar(10)
  is_active         Boolean   @default(true) @map("is_active")
  accepts_movements Boolean   @default(false) @map("accepts_movements")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime? @updatedAt @map("updated_at")

  parent            PucAccount?        @relation("PucHierarchy", fields: [parent_code], references: [code])
  children          PucAccount[]       @relation("PucHierarchy")
  journalEntryLines JournalEntryLine[]
  expenses          Expense[]
  budgets           Budget[]

  @@map("puc_account")
}

// ═══════════════════════════════════════════════════════
// PRESUPUESTO (Budget vs Execution)
// ═══════════════════════════════════════════════════════

model Budget {
  id              Int       @id @default(autoincrement())
  year            Int
  month           Int
  id_puc_account  Int       @map("id_puc_account")
  budgeted_amount Float     @map("budgeted_amount")
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")
  pucAccount      PucAccount @relation(fields: [id_puc_account], references: [id])

  @@unique([year, month, id_puc_account])
  @@map("budget")
}

// ═══════════════════════════════════════════════════════
// ACTIVOS FIJOS Y DEPRECIACIÓN
// ═══════════════════════════════════════════════════════

model FixedAsset {
  id                    Int       @id @default(autoincrement())
  name                  String
  description           String?
  acquisition_date      DateTime  @map("acquisition_date")
  acquisition_cost      Float     @map("acquisition_cost")
  useful_life_months    Int       @map("useful_life_months")
  salvage_value         Float     @default(0) @map("salvage_value")
  depreciation_method   String    @default("STRAIGHT_LINE") @map("depreciation_method")
  id_puc_asset          Int       @map("id_puc_asset")
  id_puc_depreciation   Int       @map("id_puc_depreciation")
  id_puc_accumulated    Int       @map("id_puc_accumulated")
  is_active             Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime? @updatedAt @map("updated_at")
  depreciationEntries   DepreciationEntry[]

  @@map("fixed_asset")
}

model DepreciationEntry {
  id              Int       @id @default(autoincrement())
  id_fixed_asset  Int       @map("id_fixed_asset")
  year            Int
  month           Int
  amount          Float
  accumulated     Float
  book_value      Float     @map("book_value")
  journal_entry_id Int?     @map("journal_entry_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  fixedAsset      FixedAsset @relation(fields: [id_fixed_asset], references: [id])

  @@unique([id_fixed_asset, year, month])
  @@map("depreciation_entry")
}

// ═══════════════════════════════════════════════════════
// ASIENTOS CONTABLES (Partida Doble)
// ═══════════════════════════════════════════════════════

model JournalEntry {
  id           Int       @id @default(autoincrement())
  entry_number String    @unique @map("entry_number")
  entry_date   DateTime  @map("entry_date")
  description  String
  source_type  String    @map("source_type") // SALE, EXPENSE, ADJUSTMENT, BANK_RECONCILIATION
  source_id    Int?      @map("source_id")
  status       String    @default("POSTED") // DRAFT, POSTED, VOIDED
  total_debit  Float     @map("total_debit")
  total_credit Float     @map("total_credit")
  created_by   Int?      @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime? @updatedAt @map("updated_at")

  lines        JournalEntryLine[]

  @@map("journal_entry")
}

model JournalEntryLine {
  id               Int       @id @default(autoincrement())
  id_journal_entry Int       @map("id_journal_entry")
  id_puc_account   Int       @map("id_puc_account")
  description      String?
  debit            Float     @default(0)
  credit           Float     @default(0)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime? @updatedAt @map("updated_at")

  journalEntry     JournalEntry @relation(fields: [id_journal_entry], references: [id], onDelete: Cascade)
  pucAccount       PucAccount   @relation(fields: [id_puc_account], references: [id])

  @@map("journal_entry_line")
}

// ═══════════════════════════════════════════════════════
// GASTOS Y COMPRAS
// ═══════════════════════════════════════════════════════

model ExpenseCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  expenses    Expense[]

  @@map("expense_category")
}

model Expense {
  id                  Int       @id @default(autoincrement())
  expense_number      String    @unique @map("expense_number")
  id_expense_category Int       @map("id_expense_category")
  id_puc_account      Int       @map("id_puc_account")
  id_provider         String?   @map("id_provider")
  invoice_number      String?   @map("invoice_number")
  description         String
  subtotal            Float
  tax_amount          Float     @default(0) @map("tax_amount")
  retention_amount    Float     @default(0) @map("retention_amount")
  total               Float
  expense_date        DateTime  @map("expense_date")
  due_date            DateTime? @map("due_date")
  payment_status      String    @default("PENDING") @map("payment_status") // PENDING, PAID, PARTIAL
  payment_date        DateTime? @map("payment_date")
  payment_method      String?   @map("payment_method")
  attachment_url      String?   @map("attachment_url")
  notes               String?
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime? @updatedAt @map("updated_at")

  expenseCategory     ExpenseCategory @relation(fields: [id_expense_category], references: [id])
  pucAccount          PucAccount      @relation(fields: [id_puc_account], references: [id])
  provider            Provider?       @relation(fields: [id_provider], references: [id])

  @@map("expense")
}

// ═══════════════════════════════════════════════════════
// CONCILIACIÓN BANCARIA
// ═══════════════════════════════════════════════════════

model BankAccount {
  id             Int       @id @default(autoincrement())
  name           String
  bank_name      String    @map("bank_name")
  account_number String    @map("account_number")
  account_type   String    @map("account_type") // AHORROS, CORRIENTE
  id_puc_account Int       @map("id_puc_account")
  is_active      Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  statements     BankStatement[]

  @@map("bank_account")
}

model BankStatement {
  id              Int       @id @default(autoincrement())
  id_bank_account Int       @map("id_bank_account")
  upload_date     DateTime  @default(now()) @map("upload_date")
  file_name       String    @map("file_name")
  period_start    DateTime  @map("period_start")
  period_end      DateTime  @map("period_end")
  status          String    @default("PENDING") // PENDING, RECONCILED, PARTIAL
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")

  bankAccount     BankAccount       @relation(fields: [id_bank_account], references: [id])
  transactions    BankTransaction[]

  @@map("bank_statement")
}

model BankTransaction {
  id                  Int       @id @default(autoincrement())
  id_bank_statement   Int       @map("id_bank_statement")
  transaction_date    DateTime  @map("transaction_date")
  description         String
  reference           String?
  debit               Float     @default(0)
  credit              Float     @default(0)
  balance             Float?
  matched             Boolean   @default(false)
  matched_source_type String?   @map("matched_source_type")
  matched_source_id   Int?      @map("matched_source_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime? @updatedAt @map("updated_at")

  bankStatement       BankStatement @relation(fields: [id_bank_statement], references: [id], onDelete: Cascade)

  @@map("bank_transaction")
}

// ═══════════════════════════════════════════════════════
// CERTIFICADOS DE RETENCIÓN
// ═══════════════════════════════════════════════════════

model WithholdingCertificate {
  id                 Int       @id @default(autoincrement())
  certificate_number String    @unique @map("certificate_number")
  id_provider        String    @map("id_provider")
  year               Int
  concept            String    // RETEFUENTE, RETEICA, RETEIVA
  base_amount        Float     @map("base_amount")
  rate               Float
  withheld_amount    Float     @map("withheld_amount")
  issue_date         DateTime  @map("issue_date")
  pdf_url            String?   @map("pdf_url")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime? @updatedAt @map("updated_at")

  provider           Provider  @relation(fields: [id_provider], references: [id])

  @@map("withholding_certificate")
}

// ═══════════════════════════════════════════════════════
// AUDIT LOG CONTABLE
// ═══════════════════════════════════════════════════════

model AccountingAuditLog {
  id          Int       @id @default(autoincrement())
  action      String    // CREATE, UPDATE, DELETE, VOID
  entity_type String    @map("entity_type") // JOURNAL_ENTRY, EXPENSE, BANK_RECONCILIATION, WITHHOLDING
  entity_id   Int       @map("entity_id")
  user_id     Int?      @map("user_id")
  user_name   String?   @map("user_name")
  details     String?   @db.Text // JSON string with old/new values
  ip_address  String?   @map("ip_address")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("accounting_audit_log")
}

// ═══════════════════════════════════════════════════════
// CIERRE CONTABLE (Period Closing)
// ═══════════════════════════════════════════════════════

model AccountingClosing {
  id               Int       @id @default(autoincrement())
  year             Int
  month            Int?      // null for annual closing
  closing_type     String    @map("closing_type") // MONTHLY, ANNUAL
  journal_entry_id Int?      @map("journal_entry_id")
  profit_loss      Float     @map("profit_loss")
  status           String    @default("CLOSED") // CLOSED, REVERSED
  closed_by        String?   @map("closed_by")
  createdAt        DateTime  @default(now()) @map("created_at")

  @@unique([year, month, closing_type])
  @@map("accounting_closing")
}

// ═══════════════════════════════════════════════════════
// NÓMINA COLOMBIANA
// ═══════════════════════════════════════════════════════

model Employee {
  id                  Int       @id @default(autoincrement())
  document_number     String    @unique @map("document_number")
  id_identification_type Int    @map("id_identification_type")
  name                String
  position            String
  department          String?
  hire_date           DateTime  @map("hire_date")
  base_salary         Float     @map("base_salary")
  transport_allowance Float     @default(0) @map("transport_allowance")
  is_active           Boolean   @default(true) @map("is_active")
  eps_entity          String?   @map("eps_entity")
  pension_fund        String?   @map("pension_fund")
  arl_risk_level      Int       @default(1) @map("arl_risk_level")
  bank_name           String?   @map("bank_name")
  bank_account        String?   @map("bank_account")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime? @updatedAt @map("updated_at")
  payrollEntries      PayrollEntry[]
  @@map("employee")
}

model PayrollPeriod {
  id          Int       @id @default(autoincrement())
  year        Int
  month       Int
  period_type String    @map("period_type")
  start_date  DateTime  @map("start_date")
  end_date    DateTime  @map("end_date")
  status      String    @default("DRAFT")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  entries     PayrollEntry[]
  @@map("payroll_period")
}

model PayrollEntry {
  id                  Int       @id @default(autoincrement())
  id_payroll_period   Int       @map("id_payroll_period")
  id_employee         Int       @map("id_employee")
  base_salary         Float     @map("base_salary")
  transport_allowance Float     @default(0) @map("transport_allowance")
  worked_days         Int       @default(30) @map("worked_days")
  overtime_hours      Float     @default(0) @map("overtime_hours")
  overtime_amount     Float     @default(0) @map("overtime_amount")
  commissions         Float     @default(0)
  bonuses             Float     @default(0)
  gross_salary        Float     @map("gross_salary")
  health_employee     Float     @default(0) @map("health_employee")
  pension_employee    Float     @default(0) @map("pension_employee")
  health_employer     Float     @default(0) @map("health_employer")
  pension_employer    Float     @default(0) @map("pension_employer")
  arl_employer        Float     @default(0) @map("arl_employer")
  sena_employer       Float     @default(0) @map("sena_employer")
  icbf_employer       Float     @default(0) @map("icbf_employer")
  caja_employer       Float     @default(0) @map("caja_employer")
  prima_provision     Float     @default(0) @map("prima_provision")
  cesantias_provision Float     @default(0) @map("cesantias_provision")
  int_cesantias_provision Float @default(0) @map("int_cesantias_provision")
  vacaciones_provision Float    @default(0) @map("vacaciones_provision")
  net_salary          Float     @map("net_salary")
  total_employer_cost Float     @map("total_employer_cost")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime? @updatedAt @map("updated_at")

  payrollPeriod       PayrollPeriod @relation(fields: [id_payroll_period], references: [id])
  employee            Employee     @relation(fields: [id_employee], references: [id])
  @@map("payroll_entry")
}
